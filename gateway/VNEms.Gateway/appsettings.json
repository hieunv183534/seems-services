{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "admin": {
        "ClusterId": "admin",
        "Match": {
          "Path": "{**catch-all}"
        }
      },
      "resource": {
        "ClusterId": "resource",
        "Match": {
          "Path": "/api/resource/{*any}"
        }
      }
    },
    "Clusters": {
      "admin": {
        "Destinations": {
          "admin": {
            "Address": "https://localhost:44382"
          }
        }
      },
      "resource": {
        "Destinations": {
          "resource": {
            "Address": "https://localhost:44377"
          }
        }
      }
    }
  }
}
